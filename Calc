<div class="field"><label>Foreign AC voltage (Vrms)</label><input type="number" id="dq-acv" placeholder="e.g. 0.02" oninput="calcDQ()"></div>
<div class="field"><label>Foreign DC voltage (V)</label><input type="number" id="dq-dcv" placeholder="e.g. 0.0" oninput="calcDQ()"></div>
