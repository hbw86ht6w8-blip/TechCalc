// Tower Ground
function calcTG(){
  const r=gv('tg-r'),rho=parseFloat(gs('tg-rho')),aStr=gs('tg-cond'),rods=gv('tg-rods')||0;
  const el=document.getElementById('tg-result');
  if(isNaN(r)||r<=0){el.style.display='none';return;}
  const rCM=r*30.48,a=parseFloat(aStr);
  const Rring=(rho/(2*Math.PI*Math.PI*rCM))*Math.log(2*rCM/a);
  // Each 8-ft rod contribution (Dwight, 3000 ohm-cm soil)
  const Rrod_each=rho/(2*Math.PI*243.84)*(Math.log(4*243.84/0.794)-1);
  const Rcombined=rods>0?(Rring*Rrod_each/rods)/(Rring+Rrod_each/rods):Rring;
  el.style.display='block';
  el.innerHTML=`<span class="badge ${Rcombined<=10?'bp':Rcombined<=25?'bw':'bf'}">${Rcombined<=10?'MEETS IEEE 998 (≤10Ω)':Rcombined<=25?'MEETS TIA-222 (≤25Ω)':'EXCEEDS LIMITS — ADD RODS OR ENHANCE RING'}</span>
  <div class="big">${Rcombined.toFixed(2)} Ω</div>
  <div class="lbl">Estimated combined ground resistance</div>
  <div class="note">
  <div class="rr"><span>Ring alone</span><span>${Rring.toFixed(2)} Ω</span></div>
  <div class="rr"><span>Rods contribution</span><span>${rods} rods</span></div>
  </div>`;
}

