}
function liveATS(){
  const el=document.getElementById('ats-live');if(!el)return;
  const I=parseFloat(document.getElementById('ats-i')?.value);
  const ah=parseFloat(document.getElementById('ats-ah')?.value);
  const t=parseFloat(document.getElementById('ats-t')?.value||20);
  if(isNaN(I)||isNaN(ah)){el.innerHTML='';return;}
  const cons=I*(t/3600),pct=cons/ah*100;
  el.innerHTML=`<span class="badge ${pct<5?'bp':pct<15?'bw':'bf'}">${pct<5?'ADEQUATE':'CHECK'}</span>
  <div style="font-size:18px;font-weight:600;margin-top:4px">${cons.toFixed(3)} Ah</div>
  <div style="font-size:12px;color:var(--txt2)">${t}s transfer · ${pct.toFixed(2)}% of capacity</div>`;
}
function calcStr(){
  const sys=parseFloat(document.getElementById('str-v')?.value||48);
  const cells={48:24,24:12,130:60}[sys]||24;
  const fc=parseFloat(document.getElementById('str-fc')?.value||2.20);
  const ec=parseFloat(document.getElementById('str-ec')?.value||2.35);
  const r=document.getElementById('str-result');if(!r)return;
  r.style.display='block';
  r.innerHTML=`<div class="big">${(cells*fc).toFixed(2)} V float</div><div class="note">
  <div class="rr"><span>Equalize</span><span>${(cells*ec).toFixed(2)} V</span></div>
  <div class="rr"><span>Low alarm</span><span>${(cells*1.782).toFixed(2)} V</span></div>
  <div class="rr"><span>High alarm</span><span>${(cells*2.363).toFixed(2)} V</span></div></div>`;
}
function buildMiTbl(){
  const t=document.getElementById('mi-tbl');if(!t)return;
  let h='<tr><th>Miles</th><th>Feet</th><th>Meters</th><th>km</th></tr>';
  for(let d=0.1;d<=5.005;d+=0.1){
    const mi=Math.round(d*10)/10;
    h+=`<tr><td>${mi.toFixed(1)}</td><td>${(mi*5280).toLocaleString()}</td><td>${(mi*1609.34).toFixed(0)}</td><td>${(mi*1.60934).toFixed(3)}</td></tr>`;
  }
  t.innerHTML=h;
}
function miLive(){
  const el=document.getElementById('mi-live');if(!el)return;
  const mi=parseFloat(document.getElementById('mi-q')?.value);
  if(isNaN(mi)||mi<0){el.innerHTML='';return;}
  el.innerHTML=`<div style="background:var(--bg3);border-radius:6px;padding:8px 12px;font-size:14px"><strong>${mi}</strong> mi = <strong style="color:var(--blue)">${(mi*5280).toLocaleString()}</strong> ft = ${(mi*1609.34).toFixed(0)} m = ${(mi*1.60934).toFixed(3)} km</div>`;
}
function c(src,dst,factor){
  const v2=parseFloat(document.getElementById(src)?.value);
  const d=document.getElementById(dst);
  if(d)d.value=isNaN(v2)?'':(v2*factor).toFixed(4).replace(/\.?0+$/,'');
}
function cf15(){
  const f=parseFloat(document.getElementById('tf')?.value);
  if(isNaN(f)){const tc=document.getElementById('tc');if(tc)tc.value='';tctx();return;}
  const cv=(f-32)/1.8;
  const tc=document.getElementById('tc');if(tc)tc.value=cv.toFixed(2);
  tctx(f,cv);
}
function cc15(){
  const cv=parseFloat(document.getElementById('tc')?.value);
  if(isNaN(cv)){const tf=document.getElementById('tf');if(tf)tf.value='';tctx();return;}
  const ff=cv*1.8+32;
  const tf=document.getElementById('tf');if(tf)tf.value=ff.toFixed(2);
  tctx(ff,cv);
}
function tctx(f,cv){
  const el=document.getElementById('t-ctx');if(!el)return;
  if(f===undefined){el.innerHTML='';return;}
  let msg='',col='var(--blue)';
  if(cv<0)msg='Below freezing';
  else if(cv<=20)msg='Cool — below reference temp';
  else if(cv<=30)msg='Standard ambient';
  else if(cv<=40){msg='NEBS long-term max (40°C)';col='var(--amber)';}
  else if(cv<=55){msg='HOT — NEBS short-term max';col='var(--amber)';}
  else{msg='CRITICAL — above all NEBS limits';col='var(--red)';}
  const rf=(1+0.00393*(cv-20)).toFixed(4);
  el.innerHTML=`<div style="background:var(--bg3);border-radius:5px;padding:7px 10px;font-size:12px;color:${col};margin-top:4px">${msg}<br><span style="color:var(--txt3)">Cu R correction: ×${rf} at ${cv.toFixed(1)}°C</span></div>`;
}
function tResist(){
  const el=document.getElementById('tr-result');if(!el)return;
  const tf=parseFloat(document.getElementById('tr-tf')?.value);
  if(isNaN(tf)){el.innerHTML='';return;}
  const tc=(tf-32)/1.8;
  const rf=(1+0.00393*(tc-20)).toFixed(4);
  el.innerHTML=`<div style="background:var(--bg3);border-radius:5px;padding:7px 10px;font-size:13px;margin-top:4px">At ${tf}°F: multiply Ω/kft by <strong style="color:var(--blue)">×${rf}</strong></div>`;
}
document.addEventListener('DOMContentLoaded',()=>{buildBatTbl();buildMiTbl();});

</script>
</body>
