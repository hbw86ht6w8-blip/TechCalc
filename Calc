// OTDR Distance
function calcOT(){
  const t=gv('ot-t'),iorSel=gs('ot-ior');
  document.getElementById('ot-custom-f').style.display=iorSel==='custom'?'block':'none';
  const ior=iorSel==='custom'?gv('ot-ior-c'):parseFloat(iorSel);
  const el=document.getElementById('ot-result');
  if(isNaN(t)||isNaN(ior)||t<=0){el.style.display='none';return;}
  const c=299792458;
