  <div class="lbl">Insertion loss at ${freqNames[freq]}</div>
  <div class="note">
  <div class="rr"><span>Service limit</span><span>${lim} dB</span></div>
  <div class="rr"><span>Temp correction</span><span>×${tcf.toFixed(3)}</span></div>
