}

// IOR Calibration
function calcIOR(){
  const kl=gv('ior-kl'),disp=gv('ior-disp'),set=gv('ior-set');
  const el=document.getElementById('ior-result');
  if(isNaN(kl)||isNaN(disp)||isNaN(set)||disp<=0){el.style.display='none';return;}
  const trueIOR=set*(disp/kl);
  el.style.display='block';
  el.innerHTML=`<div class="big">IOR = ${trueIOR.toFixed(5)}</div>
  <div class="lbl">Calibrated IOR for this fiber</div>
  <div class="note"><div class="rr"><span>Set this value in your OTDR for accurate distance measurements on this cable.</span></div></div>`;
}

// IOR Correction
function calcIORCorr(){
  const d=gv('iorc-d'),used=gv('iorc-used'),trueIOR=gv('iorc-true');
  const el=document.getElementById('iorc-result');
  if(isNaN(d)||isNaN(used)||isNaN(trueIOR)||d<=0){el.style.display='none';return;}
