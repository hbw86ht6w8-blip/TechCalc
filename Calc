  <div class="lbl">RSL − Threshold</div>
  <div class="note">
  <div class="rr"><span>RSL</span><span>${rsl} dBm</span></div>
  <div class="rr"><span>Threshold</span><span>${thresh} dBm</span></div>
  ${avail!==null?`<div class="rr"><span>Estimated availability</span><span class="${avail>=99.999?'pass':avail>=99.99?'pass':'warn'}">${avail.toFixed(5)}%</span></div>`:''}
  ${outHrs!==null?`<div class="rr"><span>Estimated outage/year</span><span>${outHrs<1?(outHrs*60).toFixed(1)+' min':(outHrs).toFixed(2)+' hrs'}</span></div>`:''}
  </div>`;
}

