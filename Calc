  <div class="rr"><span>In miles</span><span>${mi.toFixed(3)}</span></div>
  <div class="rr"><span>Fault ratio from A</span><span>${((ac/(ac+bc))*100).toFixed(1)}%</span></div>
  <div class="rr"><span>Temp correction</span><span>×${tcf.toFixed(4)}</span></div>
  <div class="rr"><span>Twist correction</span><span>${twist>1?'×1.02 applied':'none'}</span></div>
  </div>`;
}

