let bodRows=[];
function addBODRow(){
  const id=Date.now();
  bodRows.push(id);
  renderBODRows();
}
function renderBODRows(){
  const cont=document.getElementById('bod-logger-rows');
  if(bodRows.length===0){
    cont.innerHTML='<div style="color:var(--txt3);font-size:12px;padding:8px 0">No measurements yet. Click "+ Add Measurement Point" to start logging.</div>';
    document.getElementById('bod-logger-summary').innerHTML='';
    return;
  }
  cont.innerHTML=`<div class="logger-row" style="font-weight:600;color:var(--txt3);font-size:11px">
    <span>Location / Description</span><span>Current (A)</span><span>mV Drop</span><span>Limit (mV)</span><span></span></div>`;
  bodRows.forEach(id=>{
    const r=document.createElement('div');
    r.className='logger-row';
    r.id='brow-'+id;
    r.innerHTML=`<input type="text" id="bl-loc-${id}" placeholder="e.g. BDFB-1 strap A" oninput="updateBOD()">
    <input type="number" id="bl-i-${id}" placeholder="A" oninput="updateBOD()">
    <input type="number" id="bl-mv-${id}" placeholder="mV" step="0.1" oninput="updateBOD()">
    <input type="number" id="bl-lim-${id}" value="5" oninput="updateBOD()">
    <button class="del-btn" onclick="deleteBODRow(${id})">✕</button>`;
    cont.appendChild(r);
  });
  updateBOD();
}
function deleteBODRow(id){bodRows=bodRows.filter(r=>r!==id);renderBODRows();}
function updateBOD(){
  const sum=document.getElementById('bod-logger-summary');
  if(bodRows.length===0){sum.innerHTML='';return;}
  let rows='',fails=0,total=0;
  bodRows.forEach(id=>{
    const loc=document.getElementById('bl-loc-'+id)?.value||'—';
    const I=parseFloat(document.getElementById('bl-i-'+id)?.value);
    const mv=parseFloat(document.getElementById('bl-mv-'+id)?.value);
    const lim=parseFloat(document.getElementById('bl-lim-'+id)?.value)||5;
    if(!isNaN(I)&&!isNaN(mv)&&I>0){
      const R=(mv/I).toFixed(3);
      const ok=mv<=lim;
      if(!ok)fails++;
      total++;
      rows+=`<div class="rr"><span>${loc}</span><span class="${ok?'pass':'fail'}">${mv}mV @ ${I}A → ${R}mΩ ${ok?'✓':'✗ FAIL'}</span></div>`;
    }
  });
  if(total===0){sum.innerHTML='';return;}
  sum.innerHTML=`<div class="result" style="display:block">
  <span class="badge ${fails===0?'bp':'bf'}">${fails===0?'ALL PASS':fails+' POINT(S) FAILING'}</span>
  <div class="note">${rows}</div></div>`;
}
renderBODRows();

