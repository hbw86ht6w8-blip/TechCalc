// ─── RFL McCarty ─────────────────────────────────────────
function calcRFL(){
  const l=gv('rfl-l'),a=gv('rfl-a'),b=gv('rfl-b'),t=gv('rfl-t')||20;
  const twist=parseFloat(gs('rfl-tw'));
  const el=document.getElementById('rfl-result');
  if(isNaN(l)||isNaN(a)||isNaN(b)||l<=0){el.style.display='none';return;}
  const tcf=1/(1+0.00393*(t-20));
  const ac=a*tcf,bc=b*tcf;
  const d=(l*(ac/(ac+bc)))*twist;
  const u=gs('rfl-u');
  const ft=d/parseFloat(u);
  const mi=ft/5280;
  el.style.display='block';
  el.innerHTML=`<div class="big">${d.toFixed(0)} units from End A</div>
  <div class="lbl">Fault location (McCarty method)</div>
