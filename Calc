<option value="60">60°C (older wiring)</option>
<option value="75" selected>75°C (THWN, standard)</option>
<option value="90">90°C (THHN, XHHW)</option>
</select></div>
<div class="field"><label>Number of current-carrying conductors in conduit</label>
<select id="pdsc-ccc" onchange="calcPDSC()">
<option value="1.0">1–3 conductors (no derating)</option>
