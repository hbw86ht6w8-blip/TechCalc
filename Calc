// ─── Sync Estimator ───────────────────────────────────────
function calcSync(){
  const snr=gv('sy-snr'),att=gv('sy-att'),prof=gs('sy-prof');
  const el=document.getElementById('sy-result');
  if(isNaN(snr)||isNaN(att)){el.style.display='none';return;}
  const bwMap={adsl2p:2.2,vdsl8:8.5,vdsl17:17.6,vdsl30:30};
  const maxMap={adsl2p:24,vdsl8:50,vdsl17:100,vdsl30:200};
  const bw=bwMap[prof],maxSpeed=maxMap[prof];
  const snrLin=Math.pow(10,snr/10);
  const shannonBW=bw*1e6*Math.log2(1+snrLin)/1e6; // Mbps theoretical
  const effDown=Math.min(maxSpeed,shannonBW*0.7);
  const attPenalty=Math.max(0,(att-20)*0.8);
  const finalEst=Math.max(0.5,effDown-attPenalty);
  el.style.display='block';
  el.innerHTML=`<div class="big">~${finalEst.toFixed(0)} Mbps</div>
  <div class="lbl">Estimated downstream sync rate</div>
  <div class="note">
  <div class="rr"><span>Shannon capacity at SNR</span><span>${shannonBW.toFixed(0)} Mbps</span></div>
  <div class="rr"><span>Profile maximum</span><span>${maxSpeed} Mbps</span></div>
  <div class="rr"><span>Attenuation penalty</span><span>−${attPenalty.toFixed(0)} Mbps</span></div>
  <div style="font-size:11px;color:var(--txt3);padding-top:4px">Approximation only. Actual rate depends on DSLAM config, noise, and interleave settings.</div>
  </div>`;
}

// ─── Ground Rod Dwight ────────────────────────────────────
function calcGR(){
  const lft=gv('gr-l'),din=gv('gr-d');
  const rhoSel=gs('gr-rho');
  const rho=rhoSel==='custom'?gv('gr-cu'):parseFloat(rhoSel);
  document.getElementById('gr-custom-f').style.display=rhoSel==='custom'?'block':'none';
  const el=document.getElementById('gr-result');
  if(isNaN(lft)||isNaN(din)||isNaN(rho)||lft<=0||din<=0){el.style.display='none';return;}
  const L=lft*30.48, d=din*2.54; // convert to cm
  const R=(rho/(2*Math.PI*L))*(Math.log(4*L/d)-1);
  const twoRods=R/2*1.1; // ~10% penalty for proximity
  el.style.display='block';
  el.innerHTML=`<span class="badge ${R<25?'bp':R<100?'bw':'bf'}">${R<25?'PASS — NEC 250.56':R<100?'MARGINAL':'FAIL — MULTIPLE RODS NEEDED'}</span>
  <div class="big">${R.toFixed(1)} Ω</div>
  <div class="lbl">Single rod ground resistance (Dwight formula)</div>
  <div class="note">
  <div class="rr"><span>NEC 25Ω limit</span><span class="${R<25?'pass':'fail'}">${R<25?'PASS':'FAIL'}</span></div>
  <div class="rr"><span>2 rods in parallel (est.)</span><span>${twoRods.toFixed(1)} Ω</span></div>
  <div class="rr"><span>Rods needed for 25Ω</span><span>${Math.ceil(R/25)} rods</span></div>
  </div>`;
}

