// ─── Fresnel ──────────────────────────────────────────────
function calcFZ(){
  const f=gv('fz-f'),d=gv('fz-d'),d1in=gv('fz-d1');
  const el=document.getElementById('fz-result');
  if(isNaN(f)||isNaN(d)||f<=0||d<=0){el.style.display='none';return;}
  const dkm=d*1.60934;
  const d1km=isNaN(d1in)?dkm/2:d1in*1.60934;
  const d2km=dkm-d1km;
  const r1=17.3*Math.sqrt((d1km*d2km)/(f*dkm));
  const clearance=r1*0.6;
  const r1max=8.66*Math.sqrt(dkm/f);
  el.style.display='block';
  el.innerHTML=`<div class="big">${r1.toFixed(1)} m</div>
  <div class="lbl">First Fresnel zone radius at obstacle point</div>
  <div class="note">
  <div class="rr"><span>Required 60% clearance</span><span>${clearance.toFixed(1)} m (${(clearance*3.28084).toFixed(1)} ft)</span></div>
  <div class="rr"><span>Max radius (path midpoint)</span><span>${r1max.toFixed(1)} m</span></div>
  <div class="rr"><span>Obstacle position</span><span>${isNaN(d1in)?'Path midpoint':d1in+' mi from Tx'}</span></div>
  </div>`;
}

