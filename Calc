    ['250',255],['300',285],['350',310],['400',335],['500',380]
  ];
  const tbl=[
    {awg:'14 AWG',a60:15,a75:20,a90:25},
    {awg:'12 AWG',a60:20,a75:25,a90:30},
    {awg:'10 AWG',a60:30,a75:35,a90:40},
