<script>

function showMod(id,btn){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nb').forEach(b=>b.classList.remove('active'));
  const el=document.getElementById('page-'+id);
  if(el){el.classList.add('active');}
  if(btn)btn.classList.add('active');
  if(el){
    const fp=el.querySelector('.stab-page');
    if(fp&&!el.querySelector('.stab-page.active')){
      fp.classList.add('active');
      const fb=el.querySelector('.stab');
      if(fb)fb.classList.add('active');
    }
  }
}
function sp(id,btn){showMod(id,btn);}

// ─── Navigation ───────────────────────────────────────────

function st(mod,id,btn){
  const page=document.getElementById('page-'+mod);
  page.querySelectorAll('.stab-page').forEach(p=>p.classList.remove('active'));
  page.querySelectorAll('.stab').forEach(b=>b.classList.remove('active'));
  document.getElementById(mod+'-'+id).classList.add('active');
  btn.classList.add('active');
}
function gv(id){return parseFloat(document.getElementById(id).value);}
function gs(id){return document.getElementById(id).value;}

// ─── Murray Loop ──────────────────────────────────────────
function calcMurray(){
  const rl=gv('mu-rl'),rm=gv('mu-rm'),l=gv('mu-l');
  const t=gv('mu-t')||20;
  const el=document.getElementById('mu-result');
  if(isNaN(rl)||isNaN(rm)||isNaN(l)||rl<=0||l<=0){el.style.display='none';return;}
  const tcf=1/(1+0.00393*(t-20));
  const rm_corr=rm*tcf;
  const d=(2*rm_corr/rl)*l;
  const u=gs('mu-u');
  const ft=u==='ft'?d:u==='kft'?d*1000:u==='m'?d*3.28084:d*3280.84;
  const mi=ft/5280;
  el.style.display='block';
  el.innerHTML=`<div class="big">${d.toFixed(0)} ${u}</div>
  <div class="lbl">Distance from test point to fault</div>
  <div class="note">
  <div class="rr"><span>In feet</span><span>${ft.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g,',')}</span></div>
  <div class="rr"><span>In miles</span><span>${mi.toFixed(3)}</span></div>
  <div class="rr"><span>Fault ratio</span><span>${((rm_corr/(rl/2))*100).toFixed(1)}% of cable length</span></div>
  <div class="rr"><span>Temp correction factor</span><span>×${tcf.toFixed(4)}</span></div>
  </div>`;
}

// ─── Capacitance Open Fault ───────────────────────────────
function capTypeChange(){
  document.getElementById('cap-custom-field').style.display=gs('cap-type')==='custom'?'block':'none';
  calcCap();
}
function calcCap(){
  const c=gv('cap-c');
  const t=gs('cap-type');
  const nfmi=t==='custom'?gv('cap-cu'):parseFloat(t);
  const el=document.getElementById('cap-result');
  if(isNaN(c)||isNaN(nfmi)||nfmi<=0){el.style.display='none';return;}
  const mi=c/nfmi;
  const ft=mi*5280;
  el.style.display='block';
  el.innerHTML=`<div class="big">${ft.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g,',')} ft</div>
  <div class="lbl">Estimated distance to open</div>
  <div class="note">
  <div class="rr"><span>Miles</span><span>${mi.toFixed(3)}</span></div>
  <div class="rr"><span>Feet</span><span>${ft.toFixed(0)}</span></div>
  <div class="rr"><span>Meters</span><span>${(mi*1609.34).toFixed(0)}</span></div>
  </div>`;
}

// ─── Ohm's Law ────────────────────────────────────────────
function calcOhm(){
  const V=gv('ohm-v'),I=gv('ohm-i'),R=gv('ohm-r'),P=gv('ohm-p');
  const el=document.getElementById('ohm-result');
  const known=[!isNaN(V),!isNaN(I),!isNaN(R),!isNaN(P)].filter(Boolean).length;
  if(known<2){el.style.display='none';return;}
  let v=V,i=I,r=R,p=P;
  if(!isNaN(V)&&!isNaN(I)){r=V/I;p=V*I;}
  else if(!isNaN(V)&&!isNaN(R)){i=V/R;p=V*V/R;}
  else if(!isNaN(V)&&!isNaN(P)){i=P/V;r=V*V/P;}
  else if(!isNaN(I)&&!isNaN(R)){v=I*R;p=I*I*R;}
  else if(!isNaN(I)&&!isNaN(P)){v=P/I;r=P/(I*I);}
  else if(!isNaN(R)&&!isNaN(P)){v=Math.sqrt(P*R);i=Math.sqrt(P/R);}
  el.style.display='block';
  el.innerHTML=`<div class="note">
  <div class="rr"><span>Voltage V</span><span>${v.toFixed(4)} V</span></div>
  <div class="rr"><span>Current I</span><span>${i.toFixed(4)} A &nbsp;(${(i*1000).toFixed(2)} mA)</span></div>
  <div class="rr"><span>Resistance R</span><span>${r.toFixed(4)} Ω</span></div>
  <div class="rr"><span>Power P</span><span>${p.toFixed(4)} W &nbsp;(${(p/1000).toFixed(4)} kW)</span></div>
  </div>`;
}

// ─── DC Loop Resistance ───────────────────────────────────
function calcDCL(){
  const t=gs('dcl-awg');
  const rpu=t==='custom'?gv('dcl-cu'):parseFloat(t);
  const l=gv('dcl-l');
  const bt=gv('dcl-bt')||0, btl=gv('dcl-btl')||0;
  document.getElementById('dcl-custom-f').style.display=t==='custom'?'block':'none';
  const el=document.getElementById('dcl-result');
  if(isNaN(rpu)||isNaN(l)||l<=0){el.style.display='none';return;}
  const rl=2*(l/1000)*rpu;
  const btR=bt*2*(btl/1000)*rpu;
  const tot=rl+btR;
  const ok=tot<900;const warn=tot>=900&&tot<1700;
  el.style.display='block';
  el.innerHTML=`<span class="badge ${ok?'bp':warn?'bw':'bf'}">${ok?'PASS — DSL CAPABLE':warn?'MARGINAL — VOICE ONLY':'FAIL'}</span>
  <div class="big">${tot.toFixed(1)} Ω</div>
  <div class="lbl">Total DC loop resistance</div>
  <div class="note">
  <div class="rr"><span>Main pair loop R</span><span>${rl.toFixed(1)} Ω</span></div>
  <div class="rr"><span>Bridge tap contribution</span><span>${btR.toFixed(1)} Ω</span></div>
  <div class="rr"><span>vs ADSL2+ limit (900 Ω)</span><span class="${ok?'pass':'fail'}">${ok?'PASS':'FAIL'}</span></div>
  <div class="rr"><span>vs POTS limit (1,700 Ω)</span><span class="${tot<1700?'pass':'fail'}">${tot<1700?'PASS':'FAIL'}</span></div>
  </div>`;
}

// ─── Insulation Resistance ────────────────────────────────
function calcIR(){
  const m=gv('ir-m'),l=gv('ir-l'),t=gv('ir-t')||68;
  const el=document.getElementById('ir-result');
  if(isNaN(m)||isNaN(l)||l<=0){el.style.display='none';return;}
  const miles=l/5280;
  const norm=m*miles;
  const tcf=Math.pow(2,(t-68)/18);
  const norm_t=norm*tcf;
  const ok=norm_t>100,pass=norm_t>10;
  el.style.display='block';
  el.innerHTML=`<span class="badge ${norm_t>100?'bp':norm_t>10?'bw':'bf'}">${norm_t>100?'GOOD':norm_t>10?'MARGINAL':'FAIL — INVESTIGATE'}</span>
  <div class="big">${norm_t.toFixed(1)} MΩ·mile</div>
  <div class="lbl">Normalized insulation resistance (temp corrected)</div>
  <div class="note">
  <div class="rr"><span>Measured IR</span><span>${m} MΩ</span></div>
  <div class="rr"><span>Cable length</span><span>${miles.toFixed(3)} miles</span></div>
  <div class="rr"><span>Normalized (before temp corr)</span><span>${norm.toFixed(1)} MΩ·mile</span></div>
  <div class="rr"><span>Temp correction factor</span><span>×${tcf.toFixed(3)}</span></div>
  <div class="rr"><span>Threshold (100 MΩ·mi)</span><span class="${ok?'pass':'fail'}">${ok?'PASS':'FAIL'}</span></div>
  </div>`;
}

// ─── Voltage Drop ─────────────────────────────────────────
function calcVdrop(){
  const vs=gv('vd-vs'),iA=gv('vd-i')/1000,l=gv('vd-l');
  const rpu=parseFloat(gs('vd-awg'));
  const el=document.getElementById('vd-result');
  if(isNaN(vs)||isNaN(iA)||isNaN(l)||l<=0){el.style.display='none';return;}
  const rl=2*(l/1000)*rpu;
  const vd=iA*rl;
  const vend=vs-vd;
  el.style.display='block';
  el.innerHTML=`<div class="big">${vd.toFixed(2)} V</div>
  <div class="lbl">Voltage drop (loop resistance × current)</div>
  <div class="note">
  <div class="rr"><span>Loop resistance</span><span>${rl.toFixed(1)} Ω</span></div>
  <div class="rr"><span>Voltage at source</span><span>${vs} V</span></div>
  <div class="rr"><span>Voltage at far end</span><span class="${vend>18?'pass':'fail'}">${vend.toFixed(2)} V</span></div>
  <div class="rr"><span>Loop current</span><span>${(iA*1000).toFixed(1)} mA</span></div>
  </div>`;
}

// ─── Battery Runtime ──────────────────────────────────────
function calcBRT(){
  const ah=gv('brt-ah'),w=gv('brt-w'),volt=parseFloat(gs('brt-v')),n=parseFloat(gs('brt-n'));
  const el=document.getElementById('brt-result');
  if(isNaN(ah)||isNaN(w)||w<=0){el.style.display='none';return;}
  const I=w/volt;
  const Ir=ah/20;
  const T=Math.pow(Ir,n-1)*ah/Math.pow(I,n);
  const Ts=ah/I;
  el.style.display='block';
  el.innerHTML=`<div class="big">${T.toFixed(1)} hours</div>
  <div class="lbl">Estimated runtime (Peukert corrected)</div>
  <div class="note">
  <div class="rr"><span>Simple estimate</span><span>${Ts.toFixed(1)} hrs</span></div>
  <div class="rr"><span>Discharge current</span><span>${I.toFixed(2)} A</span></div>
  <div class="rr"><span>Controller overstate</span><span>${(((Ts-T)/T)*100).toFixed(0)}%</span></div>
  </div>`;
}

// ─── Fiber Link Budget ────────────────────────────────────
function calcFB(){
  const tx=gv('fb-tx'),rx=gv('fb-rx'),l=gv('fb-l');
  const at=parseFloat(gs('fb-atten'));
  const nc=gv('fb-nc')||0,ns=gv('fb-ns')||0;
  const el=document.getElementById('fb-result');
  if(isNaN(tx)||isNaN(rx)||isNaN(l)){el.style.display='none';return;}
  const lossF=l*at,lossC=nc*0.5,lossS=ns*0.1,lossT=lossF+lossC+lossS;
  const prx=tx-lossT,margin=prx-rx;
  const ok=margin>=3;
  el.style.display='block';
  el.innerHTML=`<span class="badge ${ok?'bp':margin>=0?'bw':'bf'}">${ok?'PASS — ADEQUATE MARGIN':margin>=0?'MARGINAL (<3dB margin)':'FAIL — INSUFFICIENT POWER'}</span>
  <div class="big">${margin.toFixed(2)} dB</div>
  <div class="lbl">System margin (RX power − sensitivity)</div>
  <div class="note">
  <div class="rr"><span>Transmit power</span><span>${tx} dBm</span></div>
  <div class="rr"><span>Fiber loss</span><span>−${lossF.toFixed(2)} dB</span></div>
  <div class="rr"><span>Connector loss (×${nc})</span><span>−${lossC.toFixed(2)} dB</span></div>
  <div class="rr"><span>Splice loss (×${ns})</span><span>−${lossS.toFixed(2)} dB</span></div>
  <div class="rr"><span>RX power</span><span>${prx.toFixed(2)} dBm</span></div>
  <div class="rr"><span>RX sensitivity</span><span>${rx} dBm</span></div>
  </div>`;
}

// ─── OTDR Distance ────────────────────────────────────────
function calcOTDR(){
  const t=gv('otdr-t'),ior=gv('otdr-ior');
  const el=document.getElementById('otdr-result');
  if(isNaN(t)||isNaN(ior)){el.style.display='none';return;}
  const c=299792458;
  const d=(c*(t*1e-9))/(2*ior);
  el.style.display='block';
