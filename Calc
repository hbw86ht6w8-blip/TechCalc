function calcRect(){
  const vdc=gv('rect-vdc'),idc=gv('rect-idc'),eff=gv('rect-eff')/100,pf=gv('rect-pf');
  const phaseStr=gs('rect-phase');
  const el=document.getElementById('rect-result');
  if(isNaN(vdc)||isNaN(idc)||idc<=0){el.style.display='none';return;}
  const [phases,vac]=[parseInt(phaseStr.split(',')[0]),parseInt(phaseStr.split(',')[1])];
  const pDC=vdc*idc,pAC=pDC/eff,sAC=pAC/pf;
  const iAC=phases===3?sAC/(Math.sqrt(3)*vac):sAC/vac;
