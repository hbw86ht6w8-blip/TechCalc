<option value="1.4690">G.654 SMF — 1.4690</option>
<option value="1.4960">OM1 MMF @ 850nm — 1.4960</option>
<option value="1.4670">OM3/OM4 MMF @ 850nm — 1.4670</option>
<option value="custom">Custom IOR</option>
</select></div>
<div id="ot-custom-f" style="display:none">
