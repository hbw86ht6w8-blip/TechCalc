  <div class="rr"><span>DC output power</span><span>${(pDC/1000).toFixed(2)} kW</span></div>
  <div class="rr"><span>AC input power</span><span>${(pAC/1000).toFixed(2)} kW</span></div>
  <div class="rr"><span>AC apparent power</span><span>${(sAC/1000).toFixed(2)} kVA</span></div>
