  const dkm=d*1.60934;
  const d1km=isNaN(d1in)?dkm/2:d1in*1.60934;
  const d2km=dkm-d1km;
  const h=(d1km*d2km)/(12.74*K);
  el.style.display='block';
  el.innerHTML=`<div class="big">${h.toFixed(2)} m</div>
  <div class="lbl">Earth bulge height at obstacle point</div>
