// ─── Load → Min Wire ─────────────────────────────────────
function calcMW(){
  const I=gv('mw-i'),cont=parseFloat(gs('mw-cont')),mat=gs('mw-mat'),temp=parseInt(gs('mw-temp'));
  const amb=parseFloat(gs('mw-amb')),bun=parseFloat(gs('mw-bun'));
  const el=document.getElementById('mw-result');
  if(isNaN(I)||I<=0){el.style.display='none';return;}
  const Ireq=I*cont;
  const gauges=['14','12','10','8','6','4','3','2','1/0','2/0','3/0','4/0','250','350','500'];
  let chosen=null,chosenBase=null;
  for(const g of gauges){
    const key=isNaN(parseFloat(g))?g:parseFloat(g);
    const row=ampTbl[key];
    if(!row)continue;
    const base=row[mat]?.[temp];
    if(!base)continue;
    const adj=base*amb*bun;
    if(adj>=Ireq){chosen=g;chosenBase=base;break;}
  }
  el.style.display='block';
  if(!chosen){el.innerHTML=`<span class="badge bf">EXCEEDS 500 kcmil — PARALLEL CONDUCTORS REQUIRED</span>`;return;}
  const adj=Math.floor(chosenBase*amb*bun);
  el.innerHTML=`<div class="big">${chosen} AWG${chosen.includes('/')||isNaN(chosen)?'':' AWG'}</div>
  <div class="lbl">Minimum wire size required</div>
  <div class="note">
  <div class="rr"><span>Load current</span><span>${I} A</span></div>
  <div class="rr"><span>Required ampacity (×${cont})</span><span>${Ireq.toFixed(1)} A</span></div>
  <div class="rr"><span>Selected wire adjusted ampacity</span><span>${adj} A</span></div>
  </div>`;
}

