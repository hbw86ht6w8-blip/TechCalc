// ─── DC Loop Qual ─────────────────────────────────────────
function calcDQ(){
  const lr=gv('dq-lr'),irTG=gv('dq-irTG'),irRG=gv('dq-irRG'),irTR=gv('dq-irTR');
  const acv=gv('dq-acv'),dcv=gv('dq-dcv'),svc=gs('dq-svc');
  const el=document.getElementById('dq-result');
  const limits={adsl2:{lr:900,ir:1},vdsl17:{lr:200,ir:1},pots:{lr:1700,ir:0.5},t1:{lr:750,ir:1}};
  const lim=limits[svc];
  if([lr,irTG,irRG,irTR,acv,dcv].some(isNaN)){el.style.display='none';return;}
  const tests=[
    {name:'Loop resistance',val:`${lr} Ω`,pass:lr<=lim.lr,limit:`≤${lim.lr} Ω`},
    {name:'IR Tip-to-Ground',val:`${irTG} MΩ`,pass:irTG>=lim.ir,limit:`≥${lim.ir} MΩ`},
    {name:'IR Ring-to-Ground',val:`${irRG} MΩ`,pass:irRG>=lim.ir,limit:`≥${lim.ir} MΩ`},
    {name:'IR Tip-to-Ring',val:`${irTR} MΩ`,pass:irTR>=lim.ir,limit:`≥${lim.ir} MΩ`},
    {name:'Foreign AC voltage',val:`${acv} Vrms`,pass:acv<0.5,limit:'<0.5 Vrms'},
    {name:'Foreign DC voltage',val:`${dcv} V`,pass:Math.abs(dcv)<1.0,limit:'<1.0 V'},
  ];
  const balance=Math.max(irTG,irRG)/Math.min(irTG,irRG);
  const allPass=tests.every(t=>t.pass);
  el.style.display='block';
  el.innerHTML=`<span class="badge ${allPass?'bp':'bf'}">${allPass?'QUALIFIED — ALL PASS':'FAIL — SEE DETAILS'}</span>
  <div class="note">${tests.map(t=>`<div class="rr"><span>${t.name}</span><span><span class="${t.pass?'pass':'fail'}">${t.pass?'✓':'✗'}</span> ${t.val} (limit: ${t.limit})</span></div>`).join('')}
  <div class="rr"><span>Pair balance ratio</span><span class="${balance<3?'pass':balance<10?'warn':'fail'}">${balance.toFixed(2)}:1</span></div>
  </div>`;
}

// ─── ADSL Estimator ───────────────────────────────────────
function calcADSL(){
  const awg=gs('adsl-awg'),l=gv('adsl-l'),bt=gv('adsl-bt')||0,btl=gv('adsl-btl')||0;
  const prof=gs('adsl-prof');
  const el=document.getElementById('adsl-result');
  if(isNaN(l)||l<=0){el.style.display='none';return;}
  const rpu={19:8.05,22:16.14,24:25.67,26:40.81}[awg];
  const apu={19:1.2,22:1.6,24:2.0,26:2.5}[awg]; // approx dB/kft at 300kHz
  const lkft=l/1000;
  const lr=2*lkft*rpu+2*(btl/1000)*rpu;
  const il=lkft*apu+(bt*btl/1000)*apu;
  const btPenalty=bt*1.5;
  const maxDown={adsl:8,adsl2:12,adsl2p:24}[prof];
  let estDown=maxDown;
  if(il<10)estDown=maxDown;
  else if(il<20)estDown=maxDown*0.85;
  else if(il<30)estDown=maxDown*0.6;
  else if(il<40)estDown=maxDown*0.35;
  else if(il<50)estDown=maxDown*0.15;
  else estDown=0;
  estDown=Math.max(0,estDown-btPenalty*0.3);
  const ok=lr<=900&&il<40&&estDown>1;
  el.style.display='block';
  el.innerHTML=`<span class="badge ${ok?'bp':estDown>0?'bw':'bf'}">${ok?'QUALIFIES':estDown>0?'MARGINAL':'FAIL — NO SYNC'}</span>
  <div class="big">~${estDown.toFixed(0)} Mbps down</div>
  <div class="lbl">Estimated sync rate (approximate)</div>
  <div class="note">
  <div class="rr"><span>Loop resistance</span><span class="${lr<=900?'pass':'fail'}">${lr.toFixed(0)} Ω (limit 900Ω)</span></div>
  <div class="rr"><span>Insertion loss @ 300kHz</span><span class="${il<40?'pass':'fail'}">${il.toFixed(1)} dB</span></div>
  <div class="rr"><span>Bridge tap penalty</span><span class="${btPenalty>0?'warn':'pass'}">−${btPenalty.toFixed(1)} dB equiv.</span></div>
  </div>`;
}

// ─── VDSL2 Estimator ─────────────────────────────────────
function calcVDSL(){
  const awg=gs('vdsl-awg'),l=gv('vdsl-l'),prof=gs('vdsl-prof'),bt=gv('vdsl-bt')||0;
  const el=document.getElementById('vdsl-result');
  if(isNaN(l)||l<=0){el.style.display='none';return;}
  const limits={'8a':5000,'12a':4000,'17a':3000,'30a':1500};
  const speeds={'8a':[50,10],'12a':[60,15],'17a':[100,40],'30a':[200,100]};
  const lim=limits[prof],spd=speeds[prof];
  const apu={19:0.7,22:1.0,24:1.4,26:2.2};
  // scale factor for freq
  const freqMult={'8a':4.0,'12a':5.5,'17a':7.0,'30a':10.0}[prof];
