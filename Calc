  const ok=l<=lim&&bt===0;
  el.style.display='block';
  el.innerHTML=`<span class="badge ${ok?'bp':l<=lim?'bw':'bf'}">${l<=lim?'IN RANGE':'EXCEEDS REACH LIMIT'}</span>
  <div class="big">~${Math.max(0,estDown).toFixed(0)} / ${Math.max(0,estUp).toFixed(0)} Mbps</div>
  <div class="lbl">Estimated down/up sync rate</div>
  <div class="note">
  <div class="rr"><span>Profile reach limit</span><span>${lim.toLocaleString()} ft</span></div>
  <div class="rr"><span>Actual distance</span><span class="${l<=lim?'pass':'fail'}">${l.toLocaleString()} ft</span></div>
  <div class="rr"><span>Est. insertion loss</span><span>${il.toFixed(1)} dB</span></div>
  <div class="rr"><span>Bridge taps (each −5%)</span><span class="${bt>0?'warn':'pass'}">${bt} taps</span></div>
  </div>`;
}

