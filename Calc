<option value="0.25">Zone 2 — 0.25g</option>
<option value="0.40">Zone 3 — 0.40g</option>
<option value="0.60" selected>Zone 4 — 0.60g</option>
</select></div>
<div class="field"><label>Equipment height (inches)</label><input type="number" id="sei-h" placeholder="e.g. 84" oninput="calcSEI()"></div>
<div id="sei-result" class="result"></div>
</div>
