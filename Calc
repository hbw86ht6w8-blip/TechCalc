// ─── Shield Continuity ────────────────────────────────────
function calcSC(){
  const t=gs('sc-type'),l=gv('sc-l'),m=gv('sc-m');
  const rpu=t==='custom'?gv('sc-cu'):parseFloat(t);
  document.getElementById('sc-custom-f').style.display=t==='custom'?'block':'none';
  const el=document.getElementById('sc-result');
  if(isNaN(rpu)||isNaN(l)||l<=0){el.style.display='none';return;}
