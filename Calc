  <div class="rr"><span>Rain rate</span><span>${R} mm/hr</span></div>
  <div class="rr"><span>Include in fade margin?</span><span class="${A>5?'fail':A>2?'warn':'pass'}">${A>5?'YES — significant':A>2?'YES — moderate':'Minor — &lt;2 dB'}</span></div>
  </div>`;
}

// ─── Fade Margin ─────────────────────────────────────────
function calcFM(){
  const rsl=gv('fm-rsl'),thresh=gv('fm-thresh'),f=gv('fm-f'),d=gv('fm-d'),c=parseFloat(gs('fm-c'));
  const el=document.getElementById('fm-result');
  if(isNaN(rsl)||isNaN(thresh)){el.style.display='none';return;}
  const fm=rsl-thresh;
  let avail=null,outage=null,outHrs=null;
  if(!isNaN(f)&&!isNaN(d)&&f>0&&d>0){
    const dkm=d*1.60934;
    const pout=c*f*Math.pow(dkm,3)*Math.pow(10,-fm/10);
    avail=(1-pout)*100;
    outage=pout;
    outHrs=pout*8760;
  }
  el.style.display='block';
  el.innerHTML=`<span class="badge ${fm>=30?'bp':fm>=20?'bw':'bf'}">${fm>=35?'EXCELLENT':fm>=30?'GOOD':fm>=20?'MARGINAL':'LOW — CONSIDER REDESIGN'}</span>
