<option value="shdsl23">SHDSL 2.3 Mbps (392 kHz, 30 dB limit)</option>
<option value="shdsl46">SHDSL 4.6 Mbps (784 kHz, 30 dB limit)</option>
</select></div>
<div class="field"><label>Cable gauge</label>
<select id="hdsl-awg" onchange="calcHDSL()">
<option value="19">19 AWG</option>
<option value="22">22 AWG</option>
<option value="24" selected>24 AWG</option>
<option value="26">26 AWG</option>
</select></div>
