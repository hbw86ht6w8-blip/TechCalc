function liveBat(){
  const el=document.getElementById('bat-live');if(!el)return;
  const ah=parseFloat(document.getElementById('br-ah')?.value);
  const cr=parseFloat(document.getElementById('br-cr')?.value||20);
  const I=parseFloat(document.getElementById('br-i')?.value);
  const n=parseFloat(document.getElementById('br-n')?.value||1.2);
  const str=parseFloat(document.getElementById('br-str')?.value||1);
  const tf=parseFloat(document.getElementById('br-tf')?.value||77);
  const soc=(parseFloat(document.getElementById('br-soc')?.value||100))/100;
  if(isNaN(ah)||isNaN(I)||ah<=0||I<=0){el.innerHTML='';return;}
  const Ir=ah/cr,tc=1+0.005*(tf-77),Ca=ah*tc*soc;
  const T=Math.pow(Ir,n-1)*Ca/Math.pow(I/str,n);
  const Ts=Ca/(I/str);
  const pct=((Ts-T)/T*100).toFixed(0);
  const col=T>4?'var(--green)':T>2?'var(--amber)':'var(--red)';
  const bw=Math.min(100,T/8*100);
  el.innerHTML=`<span class="badge ${T>4?'bp':T>2?'bw':'bf'}">${T>4?'ADEQUATE':T>2?'MARGINAL':'LOW RESERVE'}</span>
  <div style="background:var(--bg);border-radius:6px;height:14px;overflow:hidden;margin:4px 0"><div style="height:100%;width:${bw.toFixed(0)}%;background:${col};border-radius:6px"></div></div>
  <div style="font-size:22px;font-weight:600;margin-top:4px">${T.toFixed(2)} hours</div>
  <div style="font-size:12px;color:var(--txt2)">Peukert-corrected · ${I}A load · ${str} string${str>1?'s':''}</div>
  <div style="font-size:12px;color:var(--txt3);margin-top:4px;border-top:1px solid var(--border);padding-top:4px">Controller ≈${Ts.toFixed(2)} hrs · overstates ${pct}%</div>`;
}
