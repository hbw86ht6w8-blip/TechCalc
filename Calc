// 5G Small Cell
function calcFiveG(){
  const f=parseFloat(gs('fiveg-f')),eirp=gv('fiveg-eirp'),sens=gv('fiveg-sens'),env=parseFloat(gs('fiveg-env'));
  const el=document.getElementById('fiveg-result');
  if(isNaN(eirp)||isNaN(sens)){el.style.display='none';return;}
  const maxPathLoss=eirp-sens-env;
  // 3GPP path loss model for 5G
  const PL0=32.4+20*Math.log10(f);
  const n=f>=10?3.5:3.0; // path loss exponent
  const d=Math.pow(10,(maxPathLoss-PL0)/(10*n));
  el.style.display='block';
  el.innerHTML=`<div class="big">${d.toFixed(0)} m coverage radius</div>
  <div class="lbl">Estimated cell radius</div>
  <div class="note">
  <div class="rr"><span>In feet</span><span>${(d*3.28084).toFixed(0)} ft</span></div>
