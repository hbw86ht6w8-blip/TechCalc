  <div class="rr"><span>K-factor</span><span>${K}</span></div>
  <div class="rr"><span>At position</span><span>${isNaN(d1in)?'Path midpoint (worst case)':d1in+' mi from Tx'}</span></div>
  <div class="rr"><span>Note</span><span>Add Fresnel clearance to this value for total tower height requirement</span></div>
  </div>`;
}

// ─── Rain Fade ────────────────────────────────────────────
function calcRain(){
  const fsel=gs('rain-f'),rsel=gs('rain-r'),d=gv('rain-d');
  document.getElementById('rain-custom-f').style.display=rsel==='custom'?'block':'none';
  const el=document.getElementById('rain-result');
  const R=rsel==='custom'?gv('rain-cu'):parseFloat(rsel);
  if(isNaN(d)||d<=0||isNaN(R)){el.style.display='none';return;}
  const dkm=d*1.60934;
  const reff=dkm/(1+dkm/35);
  const params={
    '6':{k:0.00155,a:1.265},'11':{k:0.0188,a:1.217},
    '18':{k:0.101,a:1.060},'23':{k:0.187,a:1.000},'38':{k:0.600,a:0.890}
  };
  const p=params[fsel];
  const gamma=p.k*Math.pow(R,p.a);
  const A=gamma*reff;
  el.style.display='block';
  el.innerHTML=`<div class="big">${A.toFixed(2)} dB</div>
  <div class="lbl">Total rain attenuation on path</div>
