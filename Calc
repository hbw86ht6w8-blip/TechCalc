</div>
<div id="ot-result" class="result"></div>
<div class="divider"></div>
<h3>IOR Calibration from Known Length</h3>
<div class="field"><label>Known fiber length (meters)</label><input type="number" id="ior-kl" placeholder="e.g. 5000" oninput="calcIOR()"></div>
<div class="field"><label>OTDR displayed distance (meters)</label><input type="number" id="ior-disp" placeholder="e.g. 5034" oninput="calcIOR()"></div>
