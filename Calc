// ─── Insertion Loss ───────────────────────────────────────
function calcIL(){
  const awg=gs('il-awg'),l=gv('il-l'),freq=gs('il-freq'),t=gv('il-t')||68;
  const el=document.getElementById('il-result');
  if(isNaN(l)||l<=0){el.style.display='none';return;}
  // dB/kft coefficients by AWG and frequency
  const coeff={
    19:{adsl:1.2,adsl2p:2.5,vdsl8:6.0,vdsl17:10.0,t1:1.0},
    22:{adsl:1.6,adsl2p:3.3,vdsl8:7.8,vdsl17:12.5,t1:1.3},
    24:{adsl:2.0,adsl2p:4.0,vdsl8:9.5,vdsl17:14.0,t1:1.5},
    26:{adsl:2.5,adsl2p:5.5,vdsl8:12.5,vdsl17:20.0,t1:2.2}
  };
  const alpha=coeff[awg][freq];
  const tcf=1+0.002*((t-68));
  const il=(l/1000)*alpha*tcf;
  const freqNames={adsl:'300 kHz',adsl2p:'1.1 MHz',vdsl8:'8.5 MHz',vdsl17:'17.6 MHz',t1:'772 kHz'};
  const limits={adsl:43,adsl2p:50,vdsl8:27,vdsl17:20,t1:22.5};
  const lim=limits[freq];
  el.style.display='block';
  el.innerHTML=`<span class="badge ${il<lim*0.6?'bp':il<lim?'bw':'bf'}">${il<lim*0.6?'EXCELLENT':il<lim?'ACCEPTABLE':'EXCEEDS LIMIT'}</span>
