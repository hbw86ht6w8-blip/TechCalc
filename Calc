// ─── Freq/Wavelength ──────────────────────────────────────
function fwConv(from){
  const vals={ghz:gv('fw-ghz'),mhz:gv('fw-mhz'),cm:gv('fw-cm'),mm:gv('fw-mm')};
  const c=29979245800; // cm/s
  let fHz=NaN;
  if(from==='ghz'&&!isNaN(vals.ghz))fHz=vals.ghz*1e9;
  else if(from==='mhz'&&!isNaN(vals.mhz))fHz=vals.mhz*1e6;
  else if(from==='cm'&&!isNaN(vals.cm)&&vals.cm>0)fHz=c/vals.cm;
  else if(from==='mm'&&!isNaN(vals.mm)&&vals.mm>0)fHz=(c*10)/vals.mm;
  const el=document.getElementById('fw-result');
  if(isNaN(fHz)||fHz<=0){el.style.display='none';return;}
  const lambda_cm=c/fHz;
  if(from!=='ghz')document.getElementById('fw-ghz').value=(fHz/1e9).toFixed(6).replace(/0+$/,'');
  if(from!=='mhz')document.getElementById('fw-mhz').value=(fHz/1e6).toFixed(4).replace(/0+$/,'');
  if(from!=='cm')document.getElementById('fw-cm').value=lambda_cm.toFixed(4).replace(/0+$/,'');
  if(from!=='mm')document.getElementById('fw-mm').value=(lambda_cm*10).toFixed(4).replace(/0+$/,'');
  el.style.display='block';
  el.innerHTML=`<div class="note">
  <div class="rr"><span>Half-wave dipole length</span><span>${(lambda_cm/2*0.95).toFixed(2)} cm</span></div>
  <div class="rr"><span>Quarter-wave monopole</span><span>${(lambda_cm/4*0.95).toFixed(2)} cm</span></div>
  </div>`;
}

