function checkGas(){
  const o2=gv('gas-o2'),lel=gv('gas-lel'),co=gv('gas-co'),h2s=gv('gas-h2s');
  function setBox(id,val,label,unit,ok,warn,danger){
    const box=document.getElementById('gas-'+id+'-box');
    const valEl=document.getElementById('gas-'+id+'-val');
    const statEl=document.getElementById('gas-'+id+'-status');
    if(isNaN(val)){valEl.textContent='—'+unit;box.className='gas-box';statEl.textContent='Enter reading';statEl.style.background='';statEl.style.color='';return;}
    valEl.textContent=val+unit;
    if(danger){box.className='gas-box danger';statEl.textContent='DANGER — NO ENTRY';statEl.style.background='var(--redbg)';statEl.style.color='var(--red)';}
    else if(warn){box.className='gas-box warn';statEl.textContent='WARNING';statEl.style.background='var(--ambbg)';statEl.style.color='var(--amber)';}
    else{box.className='gas-box ok';statEl.textContent='SAFE';statEl.style.background='var(--greenbg)';statEl.style.color='var(--green)';}
  }
  setBox('o2',o2,'%','%',o2>=19.5&&o2<=23.5,(o2<19.5||o2>23.5)&&!(o2<16||o2>25),(o2<16||o2>25));
  setBox('lel',lel,'%LEL','%',lel<10,lel>=10&&lel<=25,lel>25);
  setBox('co',co,'ppm',' ppm',co<35,co>=35&&co<=200,co>200);
  setBox('h2s',h2s,'ppm',' ppm',h2s<10,h2s>=10&&h2s<=50,h2s>50);
  const vd=document.getElementById('gas-verdict');
  if([o2,lel,co,h2s].some(isNaN)){vd.innerHTML='';return;}
  const allSafe=(o2>=19.5&&o2<=23.5&&lel<10&&co<35&&h2s<10);
  const anyDanger=(o2<16||o2>25||lel>25||co>200||h2s>50);
  vd.innerHTML=`<div class="result" style="display:block;border-left-color:${anyDanger?'var(--red)':allSafe?'var(--green)':'var(--amber)'}">
  <span class="badge ${anyDanger?'bf':allSafe?'bp':'bw'}">${anyDanger?'DANGER — DO NOT ENTER':allSafe?'ATMOSPHERE SAFE — MAY ENTER':'WARNING — DO NOT ENTER'}</span>
  </div>`;
}

